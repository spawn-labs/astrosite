---
import Layout from '../../layouts/Layout.astro';
import { getPaginatedPosts } from '../../lib/posts';
import { getUnsplashImageForSlug } from '../../lib/images';

export function getStaticPaths() {
	const PAGE_SIZE = 12;
	const { totalPages } = getPaginatedPosts(1, PAGE_SIZE);

	return Array.from({ length: totalPages }, (_, index) => {
		const page = index + 1;
		const pageData = getPaginatedPosts(page, PAGE_SIZE);

		return {
			params: { page: String(page) },
			props: pageData
		};
	});
}

interface Props {
	posts: import('../../lib/posts').Post[];
	currentPage: number;
	totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props as Props;
---

<Layout
	title={currentPage === 1 ? 'Health Hearty' : `Health Hearty – Page ${currentPage}`}
	description="Browse Health Hearty articles across conditions, treatments, and wellness topics."
>
	<section class="hero">
		<div class="hero-content">
			<h1>Health Hearty articles</h1>
			<p>
				Page {currentPage} of {totalPages}. Explore more plain-language health and wellness guides.
			</p>
		</div>
	</section>

	<section aria-label={`Health Hearty articles page ${currentPage}`} class="posts-grid">
		{posts.map((post) => {
			const image = getUnsplashImageForSlug(post.slug);
			return (
				<article class="post-card" aria-labelledby={`post-${post.slug}`}>
					<a href={`/posts/${post.slug}/`} class="post-image-link" aria-hidden="true" tabindex={-1}>
						<img src={image.src} alt={post.title} loading="lazy" class="post-image" />
					</a>
					<div class="post-body">
						<h2 id={`post-${post.slug}`} class="post-title">
							<a href={`/posts/${post.slug}/`}>{post.title}</a>
						</h2>
						<p class="post-excerpt">{post.excerpt}</p>
						<div class="post-meta">
							<a href={`/posts/${post.slug}/`} class="read-more">Read article</a>
							<span class="image-credit">
								Photo by{' '}
								<a href={image.photographerUrl} target="_blank" rel="noopener noreferrer">
									{image.photographerName}
								</a>{' '}
								on{' '}
								<a href={image.unsplashUrl} target="_blank" rel="noopener noreferrer">
									Unsplash
								</a>
							</span>
						</div>
					</div>
				</article>
			);
		})}
	</section>

	{totalPages > 1 && (
		<nav class="pagination" aria-label="Pagination">
			<span class="page-label">Page {currentPage} of {totalPages}</span>
			<div class="page-links">
				{currentPage > 1 && (
					<a
						href={currentPage === 2 ? '/' : `/page/${currentPage - 1}/`}
						class="page-link"
					>
						Previous
					</a>
				)}
				{Array.from({ length: totalPages }, (_, index) => {
					const page = index + 1;
					const href = page === 1 ? '/' : `/page/${page}/`;
					const isCurrent = page === currentPage;
					return (
						<a
							href={href}
							class={`page-number ${isCurrent ? 'current' : ''}`}
							aria-current={isCurrent ? 'page' : undefined}
						>
							{page}
						</a>
					);
				})}
				{currentPage < totalPages && (
					<a href={`/page/${currentPage + 1}/`} class="page-link">
						Next
					</a>
				)}
			</div>
		</nav>
	)}
</Layout>

<style>
	.hero {
		margin-bottom: 1.75rem;
	}

	.hero-content {
		padding: 1.25rem 1.6rem;
		border-radius: 18px;
		background: radial-gradient(circle at top left, #ecfdf3 0, #e0f2fe 55%, #fefce8 100%);
		box-shadow: 0 20px 55px rgba(15, 23, 42, 0.12);
		border: 1px solid rgba(16, 185, 129, 0.2);
	}

	.hero h1 {
		margin: 0 0 0.45rem;
		font-size: clamp(1.6rem, 2vw + 1.1rem, 2.2rem);
		letter-spacing: -0.04em;
	}

	.hero p {
		margin: 0;
		font-size: 0.95rem;
		color: #4b5563;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.4rem;
	}

	.post-card {
		display: flex;
		flex-direction: column;
		border-radius: 18px;
		overflow: hidden;
		background: #ffffff;
		box-shadow: 0 16px 40px rgba(15, 23, 42, 0.12);
		border: 1px solid #e5e7eb;
	}

	.post-image-link {
		display: block;
	}

	.post-image {
		display: block;
		width: 100%;
		height: 180px;
		object-fit: cover;
	}

	.post-body {
		padding: 1rem 1.1rem 0.9rem;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}

	.post-title {
		margin: 0;
		font-size: 1rem;
		letter-spacing: -0.02em;
	}

	.post-title a {
		color: #111827;
		text-decoration: none;
	}

	.post-title a:hover,
	.post-title a:focus-visible {
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-underline-offset: 3px;
	}

	.post-excerpt {
		margin: 0;
		font-size: 0.9rem;
		color: #4b5563;
	}

	.post-meta {
		margin-top: 0.35rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
	}

	.read-more {
		font-size: 0.88rem;
		color: #047857;
		font-weight: 500;
		text-decoration: none;
	}

	.read-more::after {
		content: '→';
		margin-left: 0.2rem;
	}

	.read-more:hover,
	.read-more:focus-visible {
		text-decoration: underline;
	}

	.image-credit {
		font-size: 0.75rem;
		color: #6b7280;
	}

	.image-credit a {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.pagination {
		margin-top: 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75rem;
		font-size: 0.9rem;
	}

	.page-links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.page-link {
		padding: 0.35rem 0.8rem;
		border-radius: 999px;
		border: 1px solid #d1d5db;
		text-decoration: none;
		color: #111827;
	}

	.page-link:hover,
	.page-link:focus-visible {
		background-color: #f3f4f6;
	}

	.page-number {
		min-width: 2rem;
		text-align: center;
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
		border: 1px solid transparent;
		text-decoration: none;
		color: #4b5563;
	}

	.page-number.current {
		background-color: #047857;
		color: #f9fafb;
		border-color: #047857;
	}

	.page-number:hover,
	.page-number:focus-visible {
		background-color: #f3f4f6;
		color: #111827;
	}

	@media (max-width: 960px) {
		.posts-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.post-image {
			height: 170px;
		}
	}

	@media (max-width: 640px) {
		.hero-content {
			padding: 1.1rem 1.2rem;
		}

		.posts-grid {
			grid-template-columns: minmax(0, 1fr);
		}

		.post-image {
			height: 190px;
		}
	}
</style>

